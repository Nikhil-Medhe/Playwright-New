# Environment (dev | stage | prod | local). Affects default baseURL.
ENV=stage

# Override base URL (optional)
# BASE_URL=https://tools.cn-qam-stage.catnav.us

# Playwright
# HEADLESS=true
# TIMEOUT=30000
# SLOW_MO=500

# Credentials: JSON array of { company, username, password } or path to file
# LOGIN_USERS=[{"company":"x","username":"y","password":"z"}]
# LOGIN_USERS_FILE=Data/credentials.json

# Test data directory (default: ./Data)
# DATA_DIR=./Data

# Local run → email (for npm run test:email). Gmail: use App Password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=automation.qa.reports@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_TO=nikhil.medhe@firstsource.com
